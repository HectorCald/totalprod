{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/.*",
      "headers": {
        "cache-control": "public, max-age=0, must-revalidate"
      }
    }
  ]
}